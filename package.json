{
  "name": "scoutlgs",
  "version": "1.0.0",
  "description": "ScoutLGS - MTG Card Finder - Search across multiple Toronto area stores",
  "author": "Chris Payne",
  "license": "ISC",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "codex": "node scripts/codex-container.mjs",
    "codex:dev": "node scripts/codex-container.mjs",
    "codex:shell": "node scripts/codex-container.mjs --shell",
    "codex:build": "node scripts/codex-container.mjs --build",
    "dev": "docker compose -f docker-compose.dev.yml up -d --build",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "dev:ps": "docker compose -f docker-compose.dev.yml ps",
    "dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "secrets:setup": "node scripts/run-bash.js setup-secrets.sh",
    "secrets:setup:help": "node scripts/run-bash.js setup-secrets.sh --help",
    "secrets:setup:debug": "node scripts/run-bash.js setup-secrets.sh --debug"
  },
  "devDependencies": {
    "@nx/js": "^22.3.3",
    "@vitest/ui": "^4.0.16",
    "nx": "^22.3.3",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "nx"
    ]
  }
}
