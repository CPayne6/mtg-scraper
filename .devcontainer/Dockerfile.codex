FROM docker:29-cli

RUN apk add --no-cache \
      bash \
      ca-certificates \
      git \
      github-cli \
      nodejs \
      npm \
      openssh-client \
      ripgrep \
    && npm install --global @openai/codex pnpm@10.26.2 \
    && npm cache clean --force \
    && git config --system --add safe.directory '*'

COPY .devcontainer/codex-entrypoint.sh /usr/local/bin/codex-entrypoint
RUN chmod 755 /usr/local/bin/codex-entrypoint

ENV HOME=/root

ENTRYPOINT ["/usr/local/bin/codex-entrypoint"]
CMD ["bash"]
