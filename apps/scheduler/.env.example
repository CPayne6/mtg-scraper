# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Storefront Extraction
# Set EXTRACTION_ENABLED=true to register the nightly full-crawl cron.
EXTRACTION_ENABLED=false
EXTRACTION_CRON_TIME="0 1 * * *"
EXTRACTION_RUN_ON_INIT=false

# Hourly incremental refresh — re-scrapes only products with updated_at
# after the previous run's startedAt. Cheap and good for keeping inventory
# fresh between nightly full crawls. Default fires every hour between 9 AM
# and 9 PM in the SCHEDULE_TIMEZONE.
INCREMENTAL_EXTRACTION_ENABLED=false
INCREMENTAL_EXTRACTION_CRON_TIME="0 9-21 * * *"

# Timezone for all cron schedules
SCHEDULE_TIMEZONE=America/Toronto
