# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Product Discovery (V2 scraping)
# Set DISCOVERY_ENABLED=true to register the nightly discovery cron.
DISCOVERY_ENABLED=false
# Cron expression for discovery (default: 1 AM daily)
DISCOVERY_CRON_TIME="0 1 * * *"
# Optional: trigger discovery once on startup (handy for local testing)
DISCOVERY_RUN_ON_INIT=false

# Timezone for all cron schedules
SCHEDULE_TIMEZONE=America/Toronto
