# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=scoutlgs
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Proxy Configuration - Webshare Datacenter
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=
WEBSHARE_PORT=80
WEBSHARE_HOST=p.webshare.io
# Number of rotating proxy IPs in the Webshare pool (and the number of
# Web Bot Auth keys generated — one per proxy IP).
WEBSHARE_IP_COUNT=100

# Proxy Configuration - Webshare Rotating Residential
WEBSHARE_RESIDENTIAL_USERNAME=your_residential_username
WEBSHARE_RESIDENTIAL_PASSWORD=your_residential_password
WEBSHARE_RESIDENTIAL_PORT=80
WEBSHARE_RESIDENTIAL_HOST=p.webshare.io
