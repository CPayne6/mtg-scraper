FROM node:20
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.26.2 --activate

# Copy workspace configuration
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/core/package.json ./packages/core/
COPY apps/api/package.json ./apps/api/

# Install ALL dependencies (including dev dependencies)
RUN pnpm install --frozen-lockfile

# Copy all source code
COPY packages/shared/src ./packages/shared/src
COPY packages/shared/tsconfig.json packages/shared/tsconfig.build.json ./packages/shared/
COPY packages/core/src ./packages/core/src
COPY packages/core/tsconfig.json packages/core/tsconfig.build.json ./packages/core/
COPY apps/api/src ./apps/api/src
COPY apps/api/tsconfig.json apps/api/nest-cli.json ./apps/api/
COPY tsconfig.json nx.json ./

# Build using Nx (automatically builds dependencies)
WORKDIR /app
RUN pnpm nx build api

# Set working directory to API
WORKDIR /app/apps/api

# Expose API port
EXPOSE 5000

# Start NestJS in watch mode with hot reload
CMD ["pnpm", "dev"]
