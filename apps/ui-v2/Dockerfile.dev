FROM node:20
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.26.2 --activate

# Copy workspace configuration
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/ui-v2/package.json ./apps/ui-v2/

# Install ALL dependencies (including dev dependencies)
RUN pnpm install --frozen-lockfile

# Copy all source code
COPY packages/shared/src ./packages/shared/src
COPY packages/shared/tsconfig.json packages/shared/tsconfig.build.json ./packages/shared/
COPY apps/ui-v2/src ./apps/ui-v2/src
COPY apps/ui-v2/public ./apps/ui-v2/public
COPY apps/ui-v2/index.html apps/ui-v2/vite.config.ts apps/ui-v2/vite-env.d.ts ./apps/ui-v2/
COPY apps/ui-v2/tsconfig.json apps/ui-v2/tsconfig.app.json apps/ui-v2/tsconfig.node.json ./apps/ui-v2/
COPY tsconfig.json nx.json ./

# Build only the shared package dependency (not the UI itself)
WORKDIR /app
RUN pnpm nx build shared

# Set working directory to UI
WORKDIR /app/apps/ui-v2

# Expose Vite dev server port
EXPOSE 3000

# Start Vite dev server with hot reload
CMD ["pnpm", "dev", "--host", "0.0.0.0"]
