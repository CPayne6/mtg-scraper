PORT=5002
FRONTEND_URL=http://localhost:3001
# Set to 1 in production when auth is reachable only through a trusted proxy.
# Leave unset for direct local development so forwarded headers are ignored.
# TRUST_PROXY=1
COOKIE_SECURE=false

DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=scoutlgs_auth
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

AUTH_JWT_ISSUER=scoutlgs-auth
AUTH_JWT_AUDIENCE=scoutlgs-api
AUTH_JWT_KEY_ID=local-dev
AUTH_INTERNAL_ALLOWED_HOSTS=auth,localhost,127.0.0.1
# Production should mount this as a Docker secret file, not an env var value.
# AUTH_JWT_PRIVATE_KEY_FILE=/run/secrets/auth_jwt_private_key
# Used by scripts/setup-secrets.sh to create the Docker secret file as a one-line value.
# Generate with: openssl genpkey -algorithm Ed25519 | base64 -w 0
# AUTH_JWT_PRIVATE_KEY_BASE64=
AUTH_ACCESS_TTL_SECONDS=900
AUTH_ANON_SESSION_TTL_DAYS=90
AUTH_ANON_CREATION_LIMIT_PER_IP_DAY=20
AUTH_USER_SESSION_REFRESH_TTL_DAYS=30
AUTH_TOKEN_HASH_SECRET=dev-only-change-this-secret-value-32-chars

# Google OAuth
# Register an OAuth 2.0 Client (type "Web application") at
# https://console.cloud.google.com/apis/credentials and set the authorized
# redirect URI to AUTH_GOOGLE_CALLBACK_URL below.
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_CLIENT_SECRET_FILE=/run/secrets/auth_google_client_secret
AUTH_GOOGLE_CALLBACK_URL=http://localhost:5002/auth/google/callback
AUTH_OAUTH_STATE_COOKIE_NAME=scoutlgs_oauth_state
AUTH_OAUTH_STATE_TTL_SECONDS=600
