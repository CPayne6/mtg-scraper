# Dependencies
node_modules
**/node_modules
# Docker on Windows does not consistently match junction targets with the
# globstar form above. Keep every workspace package's host dependencies out
# of the build context; each Dockerfile runs pnpm install in Linux instead.
apps/*/node_modules
packages/*/node_modules
apps/**/node_modules/**
packages/**/node_modules/**
npm-debug.log
yarn-error.log
pnpm-debug.log

# Build outputs
dist
build
.next
out
**/dist
**/build
**/*.tsbuildinfo

# Development
.git
.gitignore
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Testing
coverage
.nyc_output
**/*.test.ts
**/*.spec.ts
**/__tests__
**/__mocks__

# Environment files at root (not needed in containers)
/.env

# Keep app-specific .env files for containers
!apps/**/.env
!apps/**/.env.example

# Documentation
*.md
!README.md
docs

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Logs
logs
*.log

# OS
Thumbs.db

# Misc
.cache
.temp
tmp
*.tmp
